  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.user-avatar {
  margin-left: 25rpx;
  margin-bottom: rpx;
}

.ai-avatar {
  margin-bottom: image.png;
  margin-left: 12rpx;
}

/* Gold accent styles */
.gold-underline {
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #FFD700 0%, #E5C07B 100%);
  border-radius: 3rpx;
  margin: 0 auto 12rpx auto;
  margin-left: 125rpx;
}
.gold-accent {
  width: 40rpx;
  height: 4rpx;
  background: #FFD700;
  border-radius: 2rpx;
  margin: 0 auto 12rpx auto;
}

/* Modern font for the whole page */
.agent-ui, .ugc-header, .ugc-title, .ugc-desc, .ugc-card, .chat-bubble, .question_content, .footer, .function, .tool_box .function {
  /* Sleeker modern typeface */
  font-family: "Inter", "Helvetica Neue", Arial, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

/* Remove gold border/shadow from card-like elements */
.ugc-card, .chat-bubble, .question_content, .system, .userContent, .con-item {
  border: 1px solid #e3eaf2;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

/* Gold dot before the title */
.ugc-title::before {
  content: none;
}

/* Gold accent for active/primary buttons */
.ugc-btn, .tool_box .function {
  border: 2px solid #2c3e50 !important;
}
.ugc-btn:active, .tool_box .function:active {
  background-color: #e3eafe !important;
  color: #2c3e50 !important;
}

/* Gold highlight for send button border */
.send-set {
  border: none;
  border-radius: 0;
  background: none;
}