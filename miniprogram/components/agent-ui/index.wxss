.tips {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  color: #007AFF;
  font-size: 12px;
  height: 32px;
  margin-bottom: 16px;
}
.tips::before,
.tips::after {
  content: '';
  display: inline-block;
  height: 1px;
  transform: scaleY(.5);
  flex-grow: 1;
  border-radius: 2px;
  background-image: linear-gradient(to right, #90CAF9, rgba(0,0,0,0));
}

.nav-content {
  /* height:62px; */
